# Mailchimp Marketing API key (Mailchimp → Account → Extras → API keys).
# The "-usXX" suffix is your data center and is required.
MAILCHIMP_API_KEY=your-api-key-us19

# Optional defaults — used when the matching tool argument is left blank.
MAILCHIMP_DEFAULT_LIST_ID=
MAILCHIMP_FROM_NAME=
MAILCHIMP_REPLY_TO=

# Comma-separated seed addresses for mailchimp_send_test (e.g. you@example.com,qa@example.com).
MAILCHIMP_TEST_EMAILS=

# Optional: restrict mailchimp_set_content_from_file to a root directory.
# Defaults to your home directory. Hidden paths and secret files are always rejected.
MAILCHIMP_CONTENT_DIR=
